@model IEnumerable<cateredByLetsuwi.Models.Booking>
@using cateredByLetsuwi.Models.Enums

@{
    ViewData["Title"] = "Booking Management Dashboard";

    decimal totalRevenue = ViewBag.TotalRevenue ?? 0;
    int totalBookings = ViewBag.TotalBookings ?? 0;
    int pendingBookings = ViewBag.PendingBookings ?? 0;

    decimal outstandingRevenue = Model
        .Where(b => b.PaymentStatus != PaymentStatus.Paid)
        .Sum(b => b.TotalPrice - b.AmountPaid);
}

<div class="container-fluid mt-4">

    <!-- ========================= -->
    <!-- PAGE HEADER -->
    <!-- ========================= -->
    <div class="row mb-4">
        <div class="col">
            <h2 class="fw-bold">Booking Management Dashboard</h2>
            <p class="text-muted">Operational overview of all catering bookings</p>
        </div>
    </div>

    <!-- ========================= -->
    <!-- KPI CARDS -->
    <!-- ========================= -->
    <div class="row g-4 mb-4">

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="text-muted">Total Revenue (Paid)</h6>
                    <h3 class="fw-bold text-success">
                        R @totalRevenue.ToString("N2")
                    </h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="text-muted">Outstanding Revenue</h6>
                    <h3 class="fw-bold text-danger">
                        R @outstandingRevenue.ToString("N2")
                    </h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="text-muted">Total Bookings</h6>
                    <h3 class="fw-bold">
                        @totalBookings
                    </h3>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h6 class="text-muted">Pending Bookings</h6>
                    <h3 class="fw-bold text-warning">
                        @pendingBookings
                    </h3>
                </div>
            </div>
        </div>

    </div>

    <!-- ========================= -->
    <!-- BOOKINGS TABLE -->
    <!-- ========================= -->
    <div class="card shadow-sm border-0">
        <div class="card-body">

            <div class="table-responsive">
                <table class="table table-hover align-middle">

                    <thead class="table-light">
                        <tr>
                            <th>Customer</th>
                            <th>Service</th>
                            <th>Event Date</th>
                            <th>Total Price</th>
                            <th>Paid</th>
                            <th>Booking Status</th>
                            <th>Payment Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var booking in Model)
                        {
                            var balance = booking.TotalPrice - booking.AmountPaid;
                            var paidPercent = booking.TotalPrice == 0
                                ? 0
                                : (booking.AmountPaid / booking.TotalPrice) * 100;

                            <tr>
                                <td>
                                    <strong>@booking.CustomerName</strong><br />
                                    <small class="text-muted">@booking.Email</small>
                                </td>

                                <td>@booking.Service?.Name</td>

                                <td>
                                    @booking.EventDate.ToString("dd MMM yyyy")
                                </td>

                                <td>
                                    R @booking.TotalPrice.ToString("N2")
                                </td>

                                <td>
                                    <div class="progress" style="height: 8px;">
                                        <div class="progress-bar bg-success"
                                             role="progressbar"
                                             style="width: @paidPercent%"
                                             aria-valuenow="@paidPercent"
                                             aria-valuemin="0"
                                             aria-valuemax="100">
                                        </div>
                                    </div>
                                    <small>
                                        R @booking.AmountPaid.ToString("N2")
                                        / R @booking.TotalPrice.ToString("N2")
                                    </small>
                                </td>

                                <td>
                                    @if (booking.BookingStatus == BookingStatus.Pending)
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else if (booking.BookingStatus == BookingStatus.Confirmed)
                                    {
                                        <span class="badge bg-primary">Confirmed</span>
                                    }
                                    else if (booking.BookingStatus == BookingStatus.Completed)
                                    {
                                        <span class="badge bg-success">Completed</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Cancelled</span>
                                    }
                                </td>

                                <td>
                                    @if (booking.PaymentStatus == PaymentStatus.Paid)
                                    {
                                        <span class="badge bg-success">Paid</span>
                                    }
                                    else if (booking.PaymentStatus == PaymentStatus.Pending)
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Unpaid</span>
                                    }
                                </td>

                                <td class="text-end">
                                    <form asp-action="UpdateStatus" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@booking.Id" />

                                        <select name="bookingStatus" class="form-select form-select-sm mb-1">
                                            @foreach (BookingStatus status in Enum.GetValues(typeof(BookingStatus)))
                                            {
                                                <option value="@status"
                                                        selected="@(booking.BookingStatus == status)">
                                                    @status
                                                </option>
                                            }
                                        </select>

                                        <select name="paymentStatus" class="form-select form-select-sm mb-1">
                                            @foreach (PaymentStatus status in Enum.GetValues(typeof(PaymentStatus)))
                                            {
                                                <option value="@status"
                                                        selected="@(booking.PaymentStatus == status)">
                                                    @status
                                                </option>
                                            }
                                        </select>

                                        <button type="submit"
                                                class="btn btn-sm btn-outline-dark w-100">
                                            Update
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>

</div>
@model cateredByLetsuwi.Models.ViewModels.RecordPaymentViewModel
@using cateredByLetsuwi.Models.Enums

@{
    ViewData["Title"] = "Record Payment";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h2 class="h4 mb-3">Record Payment</h2>

                    <div class="mb-3 text-secondary">
                        <div><strong>Customer:</strong> @Model.CustomerName</div>
                        <div><strong>Service:</strong> @Model.ServiceName</div>
                        <div><strong>Total Price:</strong> R @Model.TotalPrice.ToString("N2")</div>
                    </div>

                    <form asp-action="RecordPayment" method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="BookingId" type="hidden" />
                        <input asp-for="CustomerName" type="hidden" />
                        <input asp-for="ServiceName" type="hidden" />
                        <input asp-for="TotalPrice" type="hidden" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="AmountPaid" class="form-label"></label>
                                <input asp-for="AmountPaid" class="form-control" step="0.01" min="0" />
                                <span asp-validation-for="AmountPaid" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="PaymentStatus" class="form-label"></label>
                                <select asp-for="PaymentStatus" class="form-select" asp-items="Html.GetEnumSelectList<PaymentStatus>()"></select>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="PaymentMethod" class="form-label"></label>
                                <input asp-for="PaymentMethod" class="form-control" placeholder="EFT, Cash, Card, Transfer..." />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="PaymentReference" class="form-label"></label>
                                <input asp-for="PaymentReference" class="form-control" placeholder="Bank ref / receipt no" />
                            </div>

                            <div class="col-md-6">
                                <label asp-for="PaymentDate" class="form-label"></label>
                                <input asp-for="PaymentDate" class="form-control" type="datetime-local" />
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-luxury">Save Payment</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

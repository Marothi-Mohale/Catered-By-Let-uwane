@{
    ViewData["Title"] = "Home";
}

<section class="lux-hero py-5 py-lg-6">
    <div class="container">
        <div class="row align-items-center g-4 g-lg-5">
            <div class="col-lg-7">
                <p class="lux-kicker mb-3">Catered By Letsuwi</p>
                <h1 class="lux-display mb-3">Elevated Catering For Remarkable Events</h1>
                <p class="lux-lead mb-4">
                    A refined catering experience with elegant plating, curated menus, and seamless service from planning to presentation.
                </p>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-luxury btn-lg px-4" asp-controller="Bookings" asp-action="Create">Book Your Event</a>
                    <a class="btn btn-luxury-outline btn-lg px-4" asp-controller="Menu" asp-action="Index">Explore Menu</a>
                </div>
                <div class="d-flex flex-wrap gap-2 mt-4" aria-label="Service highlights">
                    <span class="lux-pill">Weddings</span>
                    <span class="lux-pill">Corporate</span>
                    <span class="lux-pill">Private Dining</span>
                </div>
            </div>
            <div class="col-lg-5">
                <div class="lux-photo-wrap shadow-lg">
                    <img
                        class="img-fluid lux-photo"
                        src="~/images/hero-catering.jpg"
                        alt="Elegant catering setup with plated dishes"
                        onerror="if(!this.dataset.fallback){this.dataset.fallback='1';this.src='/images/hero-catering.jpg.jpg';}else{this.style.display='none';this.nextElementSibling.classList.remove('d-none');}" />
                    <div class="lux-image-placeholder d-none" role="img" aria-label="Image placeholder for catering hero">
                        Hero image placeholder
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-white">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-6">
                <div class="lux-photo-wrap h-100">
                    <img
                        class="img-fluid lux-photo"
                        src="~/images/home-plating.jpg"
                        alt="Fine plated cuisine detail"
                        onerror="this.style.display='none';this.nextElementSibling.classList.remove('d-none');" />
                    <div class="lux-image-placeholder d-none" role="img" aria-label="Image placeholder for plated cuisine">
                        Plating image placeholder
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <h2 class="h1 lux-heading mb-3">Luxury In Every Detail</h2>
                <p class="text-secondary mb-4">
                    We pair premium ingredients with disciplined execution so each course feels intentional, memorable, and worthy of your occasion.
                </p>
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="lux-card h-100 p-3">
                            <h3 class="h6 mb-1">Curated Menus</h3>
                            <p class="mb-0 text-secondary small">Built around your guest profile and event style.</p>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="lux-card h-100 p-3">
                            <h3 class="h6 mb-1">Elegant Presentation</h3>
                            <p class="mb-0 text-secondary small">Modern service aesthetics with polished execution.</p>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="lux-card h-100 p-3">
                            <h3 class="h6 mb-1">Professional Team</h3>
                            <p class="mb-0 text-secondary small">Reliable communication and on-time coordination.</p>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="lux-card h-100 p-3">
                            <h3 class="h6 mb-1">Event Confidence</h3>
                            <p class="mb-0 text-secondary small">From intimate tables to large formal functions.</p>
                        </div>
                    </div>
                </div>
                <div class="mt-4">
                    <a class="btn btn-luxury px-4" asp-controller="Bookings" asp-action="Create">Start A Booking</a>
                </div>
            </div>
        </div>
    </div>
</section>

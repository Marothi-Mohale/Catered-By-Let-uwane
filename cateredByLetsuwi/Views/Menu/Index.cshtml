@model IEnumerable<cateredByLetsuwi.Models.Service>

@{
    ViewData["Title"] = "Menu";

    var serviceImageMap = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        ["Bespoke Wedding Banquet"] = "wedding-banquet.jpg",
        ["Executive Corporate Dining"] = "corporate-dining.jpg",
        ["Private Chef Table Experience"] = "private-chef-table.jpg",
        ["Cocktail Reception Collection"] = "cocktail-reception.jpg",
        ["Heritage Celebration Feast"] = "heritage-feast.jpg",
        ["Luxury Garden Brunch"] = "garden-brunch.jpg"
    };
}

<section class="lux-menu-hero py-5 mb-4">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-7 text-white">
                <p class="lux-kicker mb-2">Signature Selections</p>
                <h1 class="lux-display-sm mb-2">Our Catering Menu</h1>
                <p class="lux-lead mb-0">Refined service collections crafted for distinguished events.</p>
            </div>
            <div class="col-lg-5">
                <div class="lux-photo-wrap">
                    <img
                        class="img-fluid lux-photo"
                        src="~/images/menu-hero.jpg"
                        alt="Luxury catering dishes presented on table"
                        onerror="if(!this.dataset.fallback){this.dataset.fallback='1';this.src='/images/menu-hero.jpg.jpg';}else{this.style.display='none';this.nextElementSibling.classList.remove('d-none');}" />
                    <div class="lux-image-placeholder d-none" role="img" aria-label="Image placeholder for menu hero">
                        Menu hero image placeholder
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="pb-5">
    <div class="container">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <h2 class="h3 lux-heading mb-0">Service Collections</h2>
            <a class="btn btn-luxury px-4" asp-controller="Bookings" asp-action="Create">Book Catering</a>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="lux-card p-4">
                <h3 class="h5 mb-1">Menu Coming Soon</h3>
                <p class="text-secondary mb-0">Service options will appear here once they are configured.</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var item in Model)
                {
                    var imageFile = serviceImageMap.TryGetValue(item.Name, out var mapped)
                        ? mapped
                        : "menu-hero.jpg.jpg";

                    <div class="col-md-6 col-xl-4">
                        <article class="lux-card h-100 overflow-hidden">
                            <div class="lux-photo-wrap rounded-0 border-0" style="min-height: 220px;">
                                <img
                                    class="img-fluid lux-photo"
                                    src="~/images/@imageFile"
                                    alt="@item.Name catering presentation"
                                    onerror="this.style.display='none';this.nextElementSibling.classList.remove('d-none');" />
                                <div class="lux-image-placeholder d-none" role="img" aria-label="Image placeholder for @item.Name">
                                    @item.Name image placeholder
                                </div>
                            </div>

                            <div class="p-4">
                                <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                                    <h3 class="h5 mb-0">@item.Name</h3>
                                    <span class="lux-price">R @item.Price.ToString("N2")</span>
                                </div>

                                <p class="text-secondary mb-4">@item.Description</p>

                                <a class="btn btn-luxury-outline w-100" asp-controller="Bookings" asp-action="Create" aria-label="Book @item.Name catering service">
                                    Book This Service
                                </a>
                            </div>
                        </article>
                    </div>
                }
            </div>
        }
    </div>
</section>

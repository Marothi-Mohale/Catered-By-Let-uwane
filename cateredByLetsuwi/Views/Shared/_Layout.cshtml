<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - cateredByLetsuwi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/cateredByLetsuwi.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg lux-navbar sticky-top" aria-label="Main navigation">
            <div class="container-fluid px-3 px-lg-4">
                <a class="navbar-brand lux-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index" aria-label="Catered By Letsuwi home">
                    <img
                        class="lux-brand-logo"
                        src="@Url.Content("~/images/letsuwi_logo.jpg")"
                        alt="Catered By Letsuwi logo"
                        onerror="this.style.display='none';this.nextElementSibling.classList.remove('d-none');" />
                    <span class="lux-brand-fallback d-none" aria-hidden="true">CBL</span>
                    <span class="lux-brand-text">Catered By Letsuwi</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div id="mainNav" class="navbar-collapse collapse justify-content-between">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link lux-nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link lux-nav-link" asp-controller="Menu" asp-action="Index">Menu</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link lux-nav-link" asp-controller="Team" asp-action="Index">Meet the Team</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link lux-nav-link" asp-controller="Bookings" asp-action="Create">Book</a>
                        </li>

                        @if (User?.Identity?.IsAuthenticated == true && User.HasClaim("IsAdmin", "true"))
                        {
                            <li class="nav-item">
                                <a class="nav-link lux-nav-link" asp-controller="Admin" asp-action="Index">Dashboard</a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-lg-center gap-2">
                        @if (User?.Identity?.IsAuthenticated == true && User.HasClaim("IsAdmin", "true"))
                        {
                            <li class="nav-item">
                                <span class="navbar-text lux-admin-text">Hello, @User.Identity!.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-luxury-outline">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-sm btn-luxury" asp-controller="Auth" asp-action="Login">Admin Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="pb-4">
        @RenderBody()
    </main>

    <footer class="footer lux-footer text-muted">
        <div class="container py-3 d-flex flex-wrap justify-content-between gap-2">
            <span>&copy; 2026 - Catered By Letsuwi</span>
            <span class="small">Crafted for elegant events</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
